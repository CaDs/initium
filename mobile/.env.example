# Backend base URL. Use a LAN IP (not localhost) when running on a device.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# Google OAuth client IDs. Provision in Google Cloud Console; leave blank
# to gracefully disable the Google Sign-In button.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Mirror of backend DEV_BYPASS_AUTH; pre-fills a stub user when the backend
# also has it enabled. Defaults to false.
EXPO_PUBLIC_DEV_BYPASS_AUTH=false
