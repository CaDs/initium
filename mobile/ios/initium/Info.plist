<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      This Info.plist is the BASE file for the `initium` target.
      `GENERATE_INFOPLIST_FILE = YES` is also set in the project, so
      Xcode auto-generates entries from `INFOPLIST_KEY_*` build settings
      and merges them into this file at build time. That means we only
      need to declare keys here that DON'T have a build-setting alias —
      mainly `CFBundleURLTypes` (URL schemes are an array of dicts,
      which build settings can't express).

      To override the optional `Config.swift` defaults at build time,
      uncomment the keys at the bottom and edit their values.
    -->

    <!-- App Transport Security. iOS blocks cleartext HTTP by default.
         `NSAllowsLocalNetworking` relaxes the rule for `.local`
         domains, IPv4/IPv6 literals, and unqualified hosts like
         `localhost` — exactly what we need to reach the dev backend.
         Production traffic stays HTTPS-only. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>

    <!-- Magic-link deep linking. Tapping `initium://auth/verify?token=…`
         in any app routes the URL to this app, where SwiftUI's
         `.onOpenURL` (wired in initiumApp.swift) calls
         `authStore.verifyMagicLink(token:)`. -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>CFBundleURLName</key>
            <string>cads.initium</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>initium</string>
            </array>
        </dict>
    </array>

    <!--
      Optional config knobs. The defaults baked into Config.swift
      (`http://localhost:8000`, dev-bypass off, no Google client ID)
      are fine for a fresh-clone build against `make dev:backend`.
      Uncomment and edit per-fork to override.

    <key>API_BASE_URL</key>
    <string>http://localhost:8000</string>

    <key>DEV_BYPASS_AUTH</key>
    <string>false</string>

    <key>GOOGLE_IOS_CLIENT_ID</key>
    <string></string>
    -->
</dict>
</plist>
