# Server-side only
API_URL=http://localhost:8000

# Public (exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Dev bypass — skips auth on protected routes and shows the DevModeBanner.
# Server-only (no NEXT_PUBLIC_ prefix): never set to "true" in a production build.
# Must match backend DEV_BYPASS_AUTH for a coherent dev experience.
DEV_BYPASS_AUTH=false
