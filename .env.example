# Root .env — read automatically by docker-compose and the Makefile.
#
# Copy to `.env` (gitignored) and edit if you need to run multiple forks
# in parallel. The values below are the defaults — most forks won't need
# to touch this file.
#
# Which variables matter:
#   - COMPOSE_PROJECT_NAME — docker-compose names containers + volumes with
#     this prefix. Defaults to the directory name if omitted, which is
#     usually what you want (distinct directories = distinct projects).
#   - POSTGRES_PORT / MAILPIT_SMTP_PORT / MAILPIT_HTTP_PORT — host ports.
#     Change these if another fork is already using them (symptom: Docker
#     says "port is already allocated" on `make setup`).
#   - POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB — credentials +
#     database name. Change for readable `docker ps` output per fork, or
#     leave alone.

COMPOSE_PROJECT_NAME=initium

POSTGRES_USER=initium
POSTGRES_PASSWORD=initium
POSTGRES_DB=initium_dev
POSTGRES_PORT=5432

MAILPIT_SMTP_PORT=1025
MAILPIT_HTTP_PORT=8025
