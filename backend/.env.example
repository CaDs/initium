APP_ENV=development
APP_URL=http://localhost:3000
HTTP_PORT=8000
DEV_BYPASS_AUTH=true

DB_HOST=localhost
DB_PORT=5432
DB_USER=initium
DB_PASSWORD=initium
DB_NAME=initium_dev

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8000/api/auth/google/callback

JWT_PRIVATE_KEY_PATH=jwt_private.pem
JWT_PUBLIC_KEY_PATH=jwt_public.pem

SMTP_HOST=localhost
SMTP_PORT=1025
# Sender address shown in outgoing emails
SMTP_FROM=noreply@initium.local

APP_DEEP_SCHEME=initium

# Observability (optional). Backend does not wire Sentry out of the box — see
# CLAUDE.md § Observability for install + init snippet. /metrics is always on.
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
